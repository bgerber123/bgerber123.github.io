hyp=c("D.th")
diel.setup=diel.ineq()
prob.hyp=find.prob.hyp(hyp,diel.setup)
#randomly select one set of probabilities
set.seed(2323)
prob.select=prob.hyp[sample(nrow(prob.hyp),1),]
#sample size of photo events
n=100
#Simualte data
set.seed(5435334)
y=t(rmultinom(1,size=n,prob=prob.select))
y
hyp.set=hyp.sets("hyp.max")
#Specify mcmc fitting inputs
n.mcmc=2000 #number of MCMC iterations
n.cpu=1     #Number of processors to use or number of chains
burnin=1000 #burn-in period to discard from n.mcmc
out=diel.hypotheses.func(diel.setup=diel.setup,y=y,hyp.set=hyp.set,
n.mcmc=n.mcmc,n.cpu=n.cpu,burnin=burnin)
diel.plot(hyp=out$model.ms,
diel.setup=diel.setup,
posteriors=out$most.supported.model)
