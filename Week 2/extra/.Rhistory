out= apply(power,1, FUN=function(x){
pwr.t.test(d=d,power=x,type="two.sample",
alternative="two.sided")$n
})
#Sample Sizes Needed for each Group for differnt power levels
par(cex.lab=2.2,cex.axis=2.2,mar=c(5,5,1,1))
