power = 0.8
out = pwr.t.test(d=d,power=power,type="two.sample",alternative="two.sided")
#Sample Size Needed for each Group
out$n
?pwr.t.test
out = pwr.t.test(d=d,power=power,type="two.sample",alternative="two.sided",sig.level = 0.2)
#Sample Size Needed for each Group
out$n
power = 0.8
